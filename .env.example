# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/macro_platform?sslmode=require

# ── LLM — Groq (primary, free at console.groq.com — 14,400 req/day) ──────────
GROQ_API_KEY=gsk_xxxx

# ── LLM — Gemini (fallback, free at aistudio.google.com) ─────────────────────
GEMINI_API_KEY=AQ.xxxx

# ── LLM — OpenRouter (last resort, optional) ──────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Embeddings (Jina AI — 1M free tokens/month) ───────────────────────────────
JINA_API_KEY=jina_xxxx
JINA_EMBEDDING_MODEL=jina-embeddings-v3
JINA_EMBEDDING_DIMENSIONS=1024

# ── FRED (free registration at fred.stlouisfed.org) ───────────────────────────
FRED_API_KEY=your-fred-api-key

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_SECRET_KEY=change-me-in-production-32-chars-min

# ── DQ thresholds (safe defaults, no need to change) ──────────────────────────
DQ_AUTO_PROMOTE_THRESHOLD=90
DQ_REVIEW_THRESHOLD=70
REVIEW_SLA_HOURS=4
